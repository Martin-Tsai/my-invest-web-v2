{
  "version": 2,
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://investpro-api-2rr2.onrender.com/api/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
